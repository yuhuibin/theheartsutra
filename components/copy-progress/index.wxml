<view class="card progress-card">
  <view class="progress-header">
    <view class="section-title">抄写进度</view>
    <view class="status-tag {{status === 'completed' ? 'status-done' : 'status-doing'}}">
      {{status === 'completed' ? '已完成' : '进行中'}}
    </view>
  </view>
  <view class="progress-text">{{completed}} / {{total}} 行</view>
  <view class="progress-track">
    <view class="progress-bar" style="width: {{percent}}%;"></view>
  </view>
</view>
